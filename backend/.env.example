# === MI DIRECTOR FINANCIERO PTY — Backend Environment Variables ===
# Copy this file to .env and fill in the values

# Supabase (required)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key
SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Anthropic Claude (required for NLP / AI features)
ANTHROPIC_API_KEY=sk-ant-...tu-anthropic-api-key

# OpenAI (required ONLY for Whisper audio transcription)
OPENAI_API_KEY=sk-...tu-openai-api-key

# CORS — origenes permitidos separados por coma
# En produccion, agregar tu URL de Vercel
CORS_ORIGINS=http://localhost:3000,https://mi-director-financiero-pty.vercel.app

# Demo mode
DEMO_MODE=true
