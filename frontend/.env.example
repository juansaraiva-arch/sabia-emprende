# === MI DIRECTOR FINANCIERO PTY — Frontend Environment Variables ===
# Copy this file to .env.local and fill in the values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Backend API URL (required for production)
# Dev: http://localhost:8000
# Prod: tu URL de Railway, ej: https://midf-backend-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo mode — "true" para mock data sin Supabase real
NEXT_PUBLIC_DEMO_MODE=true

# Clave de acceso al equipo (opcional — si esta vacio, no pide clave)
NEXT_PUBLIC_ACCESS_PASSWORD=midf2025

# PostHog Analytics (opcional — si esta vacio, analytics desactivado)
# Crear cuenta gratis en https://posthog.com (1M eventos/mes gratis)
NEXT_PUBLIC_POSTHOG_KEY=phc_...tu-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Delighted NPS (opcional — si esta vacio, NPS desactivado)
# Crear cuenta gratis en https://delighted.com (250 respuestas/mes gratis)
NEXT_PUBLIC_DELIGHTED_KEY=tu-delighted-key
