# === SABIA EMPRENDE — Frontend Environment Variables ===
# Copy this file to .env.local and fill in the values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Backend API URL (required for production)
# Dev: http://localhost:8000
# Prod: tu URL de Railway, ej: https://sabia-emprende-backend-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo mode — "true" para mock data sin Supabase real
NEXT_PUBLIC_DEMO_MODE=true
