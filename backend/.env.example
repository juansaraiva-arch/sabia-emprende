# === SABIA EMPRENDE — Backend Environment Variables ===
# Copy this file to .env and fill in the values

# Supabase (required)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key
SUPABASE_ANON_KEY=eyJ...tu-anon-key

# OpenAI (required for NLP / AI features)
OPENAI_API_KEY=sk-...tu-openai-api-key

# CORS — origenes permitidos separados por coma
# En produccion, agregar tu URL de Vercel
CORS_ORIGINS=http://localhost:3000,https://sabia-emprende.vercel.app

# Demo mode
DEMO_MODE=true
